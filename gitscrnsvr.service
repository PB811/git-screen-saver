[Unit]
Description=gitscrnsvr — gitlogue screensaver daemon
Documentation=https://github.com/prathameshpb18/git-scrnsvr
After=gnome-session-initialized.target graphical-session.target
Requires=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/gitscrnsvr
Restart=on-failure
RestartSec=10s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=graphical-session.target
